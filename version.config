# Local build counter only.
#
# Xcode Cloud manages its own build numbers automatically — this file is ignored there.
# The MARKETING VERSION (1.0.x) is set in Xcode: target Foldiq → General → Version
# (MARKETING_VERSION in the project). Bump it there when you ship a new version.
#
# This counter just gives local test builds a unique, increasing build number
# so the version label in the app updates while developing.
CURRENT_PROJECT_VERSION=68
