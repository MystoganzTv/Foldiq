# Target-specific build-number baselines.
#
# Mac is already live in the App Store as 1.0.3 (68), so keep it frozen until
# the next real Mac release. iPhone/iPad has its own build train.
#
# Xcode Cloud can override only the iOS/iPadOS built Info.plist with
# CI_BUILD_NUMBER. Mac intentionally ignores CI_BUILD_NUMBER so web/iOS work
# does not create accidental Mac build-number churn.
#
# The MARKETING VERSION (1.0.x) is set in Xcode: target Foldiq → General → Version
# (MARKETING_VERSION in the project). Bump it there when you ship a new version.
#
# This file is intentionally not modified by local builds.
MAC_CURRENT_PROJECT_VERSION=68
IOS_CURRENT_PROJECT_VERSION=83
